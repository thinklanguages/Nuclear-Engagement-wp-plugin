{
    "name": "nuclear-engagement/plugin",
    "description": "WordPress plugin for nuclear engagement with AI-powered content generation",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6.33",
        "mockery/mockery": "^1.4",
        "wp-phpunit/wp-phpunit": "^6.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "10up/wp_mock": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "NuclearEngagement\\": "nuclear-engagement/inc/",
            "NuclearEngagement\\Admin\\": "nuclear-engagement/admin/",
            "NuclearEngagement\\Front\\": "nuclear-engagement/front/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php scripts/run-tests.php",
        "test:phpunit": "@php vendor/bin/phpunit",
        "test:coverage": "@php scripts/run-tests.php --coverage",
        "lint": "@php vendor/bin/phpcs",
        "lint:fix": "@php vendor/bin/phpcbf",
        "analyse": "@php vendor/bin/phpstan analyse --memory-limit=2G"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
